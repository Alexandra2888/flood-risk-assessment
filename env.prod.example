# Production Environment Configuration

# Backend Configuration
DEBUG=false
PORT=8000
HOST=0.0.0.0

# Anthropic AI Configuration (for image analysis)
ANTHROPIC_API_KEY=your_production_anthropic_api_key_here

# Google AI Configuration (optional, for Maps key on backend if needed)
GOOGLE_API_KEY=your_production_google_api_key_here

# Security Configuration
SECRET_KEY=your_production_secret_key_here_make_it_long_and_random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Frontend Configuration
NEXT_PUBLIC_API_URL=https://your-render-backend.onrender.com/api/v1
FRONTEND_BASE_URL=https://your-app.vercel.app

# CORS Configuration (comma-separated values)
ALLOWED_ORIGINS=https://your-app.vercel.app

# Production Settings
NODE_ENV=production

# Clerk Authentication Configuration
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_production_clerk_publishable_key_here
CLERK_SECRET_KEY=your_production_clerk_secret_key_here

# Google Maps (frontend only)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_production_google_maps_api_key_here
